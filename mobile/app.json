{
  "expo": {
    "name": "WorkOrdr",
    "slug": "workordr",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#1d4ed8"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.workordr.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1d4ed8"
      },
      "package": "com.workordr.app"
    },
    "plugins": [
      "expo-secure-store"
    ]
  }
}
