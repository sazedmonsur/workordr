{
  "expo": {
    "name": "WorkOrdr",
    "slug": "workordr",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#1d4ed8"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.workordr.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1d4ed8"
      },
      "package": "com.workordr.app",
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "WorkOrdr needs access to your photos to attach job photos.",
          "cameraPermission": "WorkOrdr needs camera access to take job site photos."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "b6d74bc1-7d4a-41f1-8978-cfe0a2bf121a"
      }
    }
  }
}
